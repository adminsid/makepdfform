{
  "name": "@makepdfform/converter",
  "version": "0.1.0",
  "description": "MakePDFForm vendored package: @makepdfform/converter (based on pdfme MIT, Copyright (c) 2020 HandDot)",
  "keywords": [
    "pdf",
    "pdf-designer",
    "pdf-generation",
    "pdf-viewer",
    "react",
    "typescript"
  ],
  "homepage": "https://makepdfform.com",
  "bugs": {
    "url": "https://github.com/pdfme/pdfme/issues"
  },
  "license": "MIT",
  "author": "Siddhartha Lama <lama@primeamericany.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adminsid/makepdfform.git"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/index.js",
      "node": "./dist/index.node.js",
      "default": "./dist/index.js"
    },
    "./md2pdf": {
      "types": "./dist/md2pdf.d.ts",
      "browser": "./dist/md2pdf.js",
      "node": "./dist/md2pdf.js",
      "default": "./dist/md2pdf.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "lint": "vp lint -c ../../.oxlintrc.json src",
    "fmt": "vp fmt -c ../../.oxfmtrc.json src --write",
    "test": "vitest run --config ../../vitest.config.ts"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.100",
    "@makepdfform/common": "*",
    "@makepdfform/pdf-lib": "*",
    "pdfjs-dist": "^5.7.284",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@makepdfform/generator": "*",
    "@makepdfform/schemas": "*",
    "@types/mdast": "^4.0.4"
  },
  "contributors": [
    {
      "name": "hand-dot",
      "url": "https://github.com/hand-dot"
    }
  ]
}
